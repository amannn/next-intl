{
  "extends": "eslint-config-molindo/tsconfig.json",
  "include": ["src"],
  "compilerOptions": {
    "lib": ["esnext", "ES2022", "ESNext.Disposable"],
    "types": ["node"],
    "target": "ES2022",
    "declaration": true,
    "rootDir": ".",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "noEmit": true
  }
}
